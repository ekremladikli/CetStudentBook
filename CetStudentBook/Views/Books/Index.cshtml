@model IEnumerable<CetStudentBook.Models.Book>

@{
    ViewData["Title"] = "Kitap Listesi";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Kitap Listesi</h2>
    <a asp-action="Create" class="btn btn-success">Yeni Kitap Ekle</a>
</div>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
    <tr>
        <th>Kitap Adı</th>
        <th>Yazar</th>
        <th>Yayın Tarihi</th>
        <th>Sayfa</th>
        <th>İkinci El</th>
        <th>İşlemler</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Author</td>
            <td>@item.PublishDate.ToShortDateString()</td>
            <td>@item.PageCount</td>
            <td>@(item.IsSecondHand ? "Evet" : "Hayır")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Düzenle</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Sil</a>
            </td>
        </tr>
    }
    </tbody>
</table>
